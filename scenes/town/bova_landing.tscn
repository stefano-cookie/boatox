npc_display_name = "Donna Rosa"
shirt_color = Color(0.75, 0.3, 0.45, 1)
greeting = "La bottega di Donna Rosa tiene in piedi mezzo paese, ma gli scaffali piangono: i mercantili non attraccano più. Tu che vai per mare, portami la roba e ti tratto bene."

[node name="DonLiborio" parent="." instance=ExtResource("2")]
