shirt_color = Color(0.7, 0.35, 0.2, 1)
greeting = "Mastro Cola, maestro d'ascia: questo molo l'ho piantato io, asse per asse. Il legname buono ormai sta in fondo al mare — se me lo porti, c'è da lavorare."

[node name="DonnaRosa" parent="." instance=ExtResource("2")]
transform = Transform3D(0.766, 0, -0.643, 0, 1, 0, 0.643, 0, 0.766, -8, 0.88, -168)
