[gd_resource type="Resource" script_class="EventDefinition" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/event_definition.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"broken_boat"
title = "Barca in avaria"
body = "Un diportista agita le braccia da una barca ferma: il motore è fuso e la corrente lo sta portando verso gli scogli. Nessun altro in vista."
choice_a = "Prendilo a rimorchio fino a Bova (-8 L)"
money_a = 40
fuel_a = -8.0
hull_a = 0.0
rep_a = 8
result_a = "Lo rimorchi in porto sano e salvo: la famiglia insiste per ricompensarti (+40 $)"
choice_b = "Segnala la posizione alla capitaneria e prosegui"
money_b = 0
fuel_b = 0.0
hull_b = 0.0
rep_b = -4
result_b = "Qualcuno lo recupererà. In paese, però, certe cose si ricordano"
