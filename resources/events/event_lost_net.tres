[gd_resource type="Resource" script_class="EventDefinition" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/event_definition.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"lost_net"
title = "Rete smarrita"
body = "Una rete da posta strappata galleggia a pelo d'acqua, quasi invisibile: un pericolo per l'elica di chiunque passi di qui. Ha i galleggianti marchiati di Bova."
choice_a = "Recuperala a bordo"
money_a = 15
fuel_a = 0.0
hull_a = 0.0
rep_a = 8
result_a = "I pescatori la riconoscono: ti offrono una ricompensa (+15 $) e un caffè che vale di più"
choice_b = "Passa alla larga"
money_b = 0
fuel_b = 0.0
hull_b = 0.0
rep_b = -3
result_b = "Qualcun altro ci finirà sopra, prima o poi. Speriamo non con l'elica"
