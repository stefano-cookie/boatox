[gd_resource type="Resource" script_class="EventDefinition" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/event_definition.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"storm_front"
title = "Muro di pioggia"
body = "Davanti a te il cielo è diventato di piombo: un fronte di burrasca taglia la tua rotta da parte a parte. Non è largo, ma picchia."
choice_a = "Dritto in mezzo (-12 scafo)"
money_a = 0
fuel_a = 0.0
hull_a = -12.0
rep_a = 0
result_a = "Ne esci fradicio e ammaccato, ma la rotta è salva ed è già passata"
choice_b = "Largo giro prudente (-6 L)"
money_b = 0
fuel_b = -6.0
hull_b = 0.0
rep_b = 0
result_b = "Allunghi la rotta e la burrasca ti sfila accanto, brontolando"
