[ext_resource type="Script" path="res://scripts/event_definition.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"mystery_buoy"
title = "Boa misteriosa"
body = "Una boa che non è segnata sulle carte, incrostata e pesante. Sotto potrebbe esserci una nassa piena — o solo un cavo arrugginito pronto a graffiarti la chiglia."
choice_a = "Tirala su (-6 scafo)"
money_a = 60
fuel_a = 0.0
hull_a = -6.0
rep_a = 0
result_a = "La nassa è piena! La vendi al volo a una barca di passaggio (+60 $), ma la fiancata si è graffiata"
choice_b = "Meglio non toccarla"
money_b = 0
fuel_b = 0.0
hull_b = 0.0
rep_b = 0
result_b = "Ti allontani: certe cose, in mare, si lasciano stare"
